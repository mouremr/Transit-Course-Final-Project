{UTF-8}
Train use growth=
	Total Traffic*Train percentage
	~	
	~		|

Car Model=
	100-0.047*Gas Price-0.0034*insurance cost-0.0062*Maintenance Cost
	~	
	~		|

Bus Model=
	40+0.02*Bike space+0.046*Bus capacity-0.0057*Distance to stop+0.07*Saftey-0.023*Ticket price
	~	
	~		|

Bus Percentage=
	EXP(Bus Model)/(EXP(Bus Model)+EXP(Car Model)+EXP(Train Model))
	~	
	~		|

Car use growth=
	Total Traffic*Car percentage
	~	
	~		|

Bus use growth=
	Bus Percentage*Total Traffic
	~	
	~		|

Train Model=
	4+Bike space*0.004-Distance to stop*0.065+Saftey*0.03-Ticket price*0.007+Train Capacity\
		*0.06+Luggage Space*0.0078
	~	
	~		|

Car percentage=
	EXP(Car Model)/(EXP(Bus Model)+EXP(Train Model)+EXP(Car Model))
	~	
	~		|

Train percentage=
	EXP(Train Model)/(EXP(Bus Model)+EXP(Car Model)+EXP(Train Model))
	~	
	~		|

Total Traffic=
	100000
	~	
	~		|

Car Use= INTEG (
	Car use growth,
		1000)
	~	
	~		|

Bus Use= INTEG (
	Bus use growth,
		100)
	~	
	~		|

Train Use= INTEG (
	Train use growth,
		300)
	~	
